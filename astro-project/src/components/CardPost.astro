---
// src/components/CardPost.astro
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tag?: string;
}

const { title, description, pubDate, slug, tag = "Estrategias Aula" } = Astro.props;

// Formatear fecha de forma elegante
const fechaFormateada = new Date(pubDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-all duration-200 group flex flex-col justify-between h-full">
  <div>
    <!-- Categoría -->
    <span class="bg-sky-50 text-sky-700 text-xs px-2.5 py-1 rounded font-semibold w-max mb-3.5 inline-block text-transform uppercase tracking-wider">
      {tag}
    </span>
    
    <!-- Título con enlace -->
    <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-sky-600 transition-colors line-clamp-2">
      <a href={`/blog/${slug}`}>
        {title}
      </a>
    </h3>
    
    <!-- Extracto breve de descripción -->
    <p class="text-slate-600 text-sm mb-5 line-clamp-3 leading-relaxed">
      {description}
    </p>
  </div>
  
  <!-- Footer de la tarjeta con fecha y enlace -->
  <div class="flex items-center justify-between border-t border-slate-50 pt-4 mt-auto">
    <time class="text-xs font-mono text-slate-400" datetime={pubDate.toString()}>
      {fechaFormateada}
    </time>
    
    <a 
      href={`/blog/${slug}`} 
      class="text-xs font-semibold text-sky-600 group-hover:text-sky-700 flex items-center gap-1 transition-colors"
    >
      Leer más 
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
  </div>
</article>
