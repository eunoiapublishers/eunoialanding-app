---
// src/components/FormularioLead.astro
---

<div class="w-full max-w-md mx-auto" id="lead-container">
  <form id="formulario-lead" class="flex flex-col text-left">
    <div class="mb-4">
      <label for="first_name" class="block text-sm font-semibold text-slate-700 mb-1">Nombre</label>
      <input 
        type="text" 
        id="first_name" 
        name="first_name" 
        required 
        placeholder="Tu nombre aquí" 
        class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500 bg-slate-50 text-slate-900 transition-all duration-150"
      />
    </div>

    <div class="mb-5">
      <label for="email" class="block text-sm font-semibold text-slate-700 mb-1">Correo Electrónico</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        placeholder="ejemplo@correo.com" 
        class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500 bg-slate-50 text-slate-900 transition-all duration-150"
      />
    </div>

    <button 
      type="submit" 
      id="btn-submit" 
      class="w-full bg-sky-600 hover:bg-sky-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors duration-200 shadow-md shadow-sky-100 flex items-center justify-center cursor-pointer"
    >
      <span id="btn-text">Unirse a la Newsletter y Descargar</span>
      <span id="btn-spinner" class="hidden ml-2">
        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </span>
    </button>
  </form>

  <!-- Bloque de Éxito Oculto Inicialmente -->
  <div id="mensaje-exito" class="hidden bg-emerald-50 text-emerald-800 p-6 rounded-xl border border-emerald-100 text-center transition-all duration-300">
    <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h3 class="font-bold text-lg mb-1 text-emerald-900">¡Te has unido con éxito!</h3>
    <p class="text-sm">Hemos enviado un correo de bienvenida. Revisa tu bandeja de entrada y tu carpeta de spam para descargar tus recursos pedagógicos gratuitos.</p>
  </div>

  <!-- Mensaje de Error Oculto -->
  <div id="mensaje-error" class="hidden mt-3 bg-rose-50 text-rose-800 p-4 rounded-lg border border-rose-100 text-sm text-center">
    Ocurrió un error. Por favor intenta de nuevo o contáctanos a soporte@eunoialearning.com.
  </div>
</div>

<script>
  // Puedes definir tu backend URL en tu archivo .env como PUBLIC_RENDER_BACKEND_URL
  const RENDER_BACKEND_URL = (import.meta as any).env?.PUBLIC_RENDER_BACKEND_URL || 'https://tu-backend-en-render.onrender.com';

  const form = document.getElementById('formulario-lead') as HTMLFormElement;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLSpanElement;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Bloquear elementos visualmente
      btnSubmit.disabled = true;
      btnSubmit.classList.add('opacity-70', 'cursor-not-allowed');
      btnText.textContent = "Procesando...";
      btnSpinner.classList.remove('hidden');

      const formData = new FormData(form);
      const data = {
        first_name: formData.get('first_name'),
        email: formData.get('email'),
        tags: ["Lead-TpT"]
      };

      // TÁCTICA FIRE-AND-FORGET (Evita el cuello de botella del Cold Start de 50s de Render)
      // Iniciamos el fetch pero NO hacemos 'await' ni bloqueamos la UI esperando la respuesta de Render.
      fetch(`${RENDER_BACKEND_URL}/api/leads`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data),
        // Solicitamos omitir mantener la conexión HTTP abierta innecesariamente larga
        keepalive: true 
      }).catch(err => {
        // Como es fire-and-forget, se loguea en background silenciosamente
        console.warn('Registro de backup en background falló o fue cancelado:', err);
      });

      // Redirigir de manera inmediata al usuario a la página de agradecimiento
      // Esto hace que la experiencia de usuario sea instantánea (< 100ms)
      setTimeout(() => {
        window.location.href = "/gracias";
      }, 150);
    });
  }
</script>
