---
// src/layouts/LayoutPrincipal.astro
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Recursos educativos y materiales didácticos para el desarrollo de personas neurodivergentes - Eunoia Learning LLC" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Eunoia Learning LLC</title>
    
    <!-- Google Fonts: Inter y JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <style>
      body {
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
      }
    </style>
  </head>
  <body class="bg-[#F8FAFC] text-[#0F172A] min-h-screen flex flex-col justify-between selection:bg-sky-100 selection:text-sky-900">
    
    <!-- Cabecera Estática (Header / Navbar) -->
    <header class="h-16 bg-white border-b border-slate-100 sticky top-0 z-50 transition-shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="text-xl font-bold text-slate-900 tracking-tight flex items-center gap-2">
            <!-- Icon/Logo sutil -->
            <span class="w-8 h-8 rounded-lg bg-sky-600 flex items-center justify-center text-white text-base font-extrabold shadow-sm shadow-sky-200">E</span>
            Eunoia Learning <span class="text-xs font-semibold text-sky-600 bg-sky-50 px-2 py-0.5 rounded ml-1 hidden sm:inline-block">LLC</span>
          </a>
        </div>
        
        <nav class="flex items-center gap-6">
          <a href="/#blog" class="text-sm font-medium text-slate-600 hover:text-sky-600 transition-colors">Artículos</a>
          <a 
            href="https://www.teacherspayteachers.com/" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-sm font-semibold text-white bg-sky-600 hover:bg-sky-700 px-4 py-2 rounded-lg transition-colors duration-150 flex items-center gap-1 shadow-sm"
          >
            Recursos en TpT
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <!-- Contenido Principal -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer Corporativo -->
    <footer class="bg-white border-t border-slate-100 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
        <div>
          <h4 class="text-base font-bold text-slate-900">Eunoia Learning LLC</h4>
          <p class="text-sm text-slate-500 mt-1 max-w-sm">Especialistas en materiales didácticos, apoyo pedagógico y adaptaciones para la neurodivergencia.</p>
        </div>
        <div class="flex flex-col items-center md:items-end gap-2 text-xs text-slate-400">
          <p>&copy; 2026 Eunoia Learning LLC. Todos los derechos reservados.</p>
          <div class="flex gap-4 mt-1">
            <a href="https://www.teacherspayteachers.com/" class="hover:text-sky-600 transition-colors">Tienda TpT</a>
            <span class="text-slate-200">|</span>
            <a href="/#lead-container" class="hover:text-sky-600 transition-colors">Newsletter</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
