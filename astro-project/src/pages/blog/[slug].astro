---
// src/pages/blog/[slug].astro
import { getCollection } from 'astro:content';
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const fechaFormateada = new Date(post.data.pubDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<LayoutPrincipal title={post.data.title} description={post.data.description}>
  <article class="bg-white py-12 border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4">
      
      <!-- Botón de regreso -->
      <a href="/" class="text-xs font-semibold text-slate-500 hover:text-sky-600 flex items-center gap-1 mb-8 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Regresar al inicio o ver recursos
      </a>
      
      <!-- Encabezado del artículo -->
      <header class="mb-10 text-left">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-sky-50 text-sky-700 text-xs px-2.5 py-1 rounded font-bold tracking-wide uppercase">
            {post.data.tag}
          </span>
          <time class="text-xs text-slate-400 font-mono" datetime={post.data.pubDate.toString()}>
            {fechaFormateada}
          </time>
        </div>
        
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight mb-4">
          {post.data.title}
        </h1>
        
        <p class="text-lg text-slate-500 font-normal leading-relaxed mb-6">
          {post.data.description}
        </p>
        
        <!-- Autor -->
        <div class="flex items-center gap-3 border-t border-b border-slate-100 py-3 mt-6">
          <div class="w-8 h-8 rounded-full bg-sky-100 flex items-center justify-center font-bold text-sky-700 text-xs">EL</div>
          <div class="text-left">
            <span class="block text-xs font-semibold text-slate-800">{post.data.author}</span>
            <span class="block text-[10px] text-slate-400">Canal de Divulgación de Recursos Didácticos</span>
          </div>
        </div>
      </header>

      <!-- SECCIÓN 3: Estilos de Markdown (Renderizado) estilizado manualmente -->
      <div class="prose prose-slate max-w-none text-left">
        <!-- Renderizado del markdown inyectado por Astro -->
        <Content />
      </div>

      <!-- Enlace final a TpT complementario al pie del artículo -->
      <div class="bg-slate-50 rounded-xl p-6 border border-slate-100 text-center mt-12">
        <h4 class="font-bold text-slate-900 text-base mb-1">🎁 ¿Deseas aplicar esta metodología en tu salón?</h4>
        <p class="text-sm text-slate-500 mb-4">Descarga el pack completo con pictogramas, organizadores y tableros listos para imprimir hoy.</p>
        <a 
          href="https://www.teacherspayteachers.com/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-sky-600 hover:bg-sky-700 text-white text-sm font-semibold py-2.5 px-5 rounded-lg inline-block transition-colors shadow-sm"
        >
          Visitar Eunoia Learning en TpT
        </a>
      </div>
      
    </div>
  </article>

  <!-- CSS manual incrustado para imitar la tipografía solicitada de Markdown si prose no estuviera cargado -->
  <style is:global>
    .prose h1 {
      font-size: 1.875rem !important; /* text-3xl */
      font-weight: 800 !important;
      color: #0F172A !important; /* slate-900 */
      margin-bottom: 1rem !important;
    }
    .prose h2 {
      font-size: 1.5rem !important; /* text-2xl */
      font-weight: 700 !important;
      color: #1E293B !important; /* slate-800 */
      margin-top: 2rem !important;
      margin-bottom: 1rem !important;
    }
    .prose p {
      font-size: 1rem !important; /* text-base */
      color: #334155 !important; /* slate-700 */
      line-height: 1.75 !important; /* leading-relaxed */
      margin-bottom: 1.5rem !important;
    }
    .prose ul {
      list-style-type: disc !important;
      padding-left: 1.25rem !important; /* pl-5 */
      margin-bottom: 1rem !important;
    }
    .prose li {
      margin-bottom: 0.5rem !important;
      color: #334155 !important;
    }
    .prose blockquote {
      border-left-width: 4px !important;
      border-color: #0284C7 !important; /* sky-500 */
      background-color: #F0F9FF !important; /* sky-50 */
      padding: 1rem !important;
      font-style: italic !important;
      margin-top: 1.5rem !important;
      margin-bottom: 1.5rem !important;
      color: #1E293B !important;
      border-top-right-radius: 0.5rem !important;
      border-bottom-right-radius: 0.5rem !important;
    }
    .prose a {
      color: #0284C7 !important;
      text-decoration-line: underline !important;
      font-weight: 600 !important;
    }
    .prose strong {
      color: #0F172A !important;
      font-weight: 700 !important;
    }
  </style>
</LayoutPrincipal>
